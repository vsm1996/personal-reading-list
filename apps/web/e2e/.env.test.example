# E2E test environment variables
# Copy this file to e2e/.env.test and fill in the values.
# Never commit e2e/.env.test — it is in .gitignore.

# Test user credentials (will be created/deleted by global-setup/teardown)
E2E_EMAIL=e2e-test@example.com
E2E_PASSWORD=e2e-test-password-123

# Supabase service-role key (admin access, needed to create/delete the test user)
# Found in: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Already in .env.local — copy here so the E2E runner can read it standalone
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Optional: override the base URL (defaults to http://localhost:3000)
# E2E_BASE_URL=http://localhost:3000
