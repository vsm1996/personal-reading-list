# Supabase — find these in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_<key>

# Prisma — find these in Supabase project settings > Database > Connection string
# Use the "Transaction" pooler URL for DATABASE_URL (pgBouncer, port 6543)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true

# Use the direct connection URL for DIRECT_URL (port 5432, for migrations)
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Book API — leave blank to use Open Library (no key required)
# Set this to use Google Books instead (get a key at console.cloud.google.com)
GOOGLE_BOOKS_API_KEY=
